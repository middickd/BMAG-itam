# Copy this file to  config/app.env  and fill in the values.
# config/app.env is gitignored and is NOT baked into the image — docker-compose
# injects it at runtime via `env_file`. Never commit real secrets.

# ----- Public base URL — used for the OIDC redirect URI and Secure cookies -----
# Must match the redirect URI registered in the Entra app + how users reach the app.
APP_BASE_URL=https://itam.bobmoore.com

# ----- Microsoft Entra ID (SSO) -----
ENTRA_TENANT_ID=68d8e8bc-e77b-496d-88a6-36e205fe75e6
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Members of this Entra group become admins; everyone else is read-only.
# Leave empty to make every signed-in user an admin.
ENTRA_ADMIN_GROUP_ID=

# ----- Session signing key — generate a strong random value -----
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ----- Optional: force the auth mode (entra | bypass).
# Leave unset to auto-detect: real SSO when the Entra creds above are present,
# otherwise bypass (dev admin). Do NOT use bypass in production. -----
# AUTH_MODE=entra

# ----- Optional: Freshservice creds for the `npm run sync-fs` CLI only.
# The running app stores Freshservice creds in its database (Settings UI), so the
# app itself does NOT need these. -----
# FRESHSERVICE_DOMAIN=yourcompany.freshservice.com
# FRESHSERVICE_API_KEY=
