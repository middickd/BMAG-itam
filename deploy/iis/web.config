<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy for BMAG-itam.

  Place this web.config as the content of an empty IIS site (e.g. physical path
  C:\inetpub\itam-proxy) bound to https://itam.bobmoore.com:443 with your public
  cert. It forwards every request to the Docker container published on the host's
  loopback at 127.0.0.1:4000. See deploy/iis/README.md for full setup.

  Requires the IIS "URL Rewrite" and "Application Request Routing" (ARR) modules,
  with ARR proxy enabled at the server level.

  The app needs no X-Forwarded-* headers: it sets Secure cookies from NODE_ENV and
  derives all URLs from APP_BASE_URL. The browser->IIS leg is HTTPS (cookies work);
  IIS->container is HTTP on loopback.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToITAM" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Let the app's own JSON error responses pass through unchanged instead of
         IIS substituting its custom error pages. -->
    <httpErrors existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <!-- 50 MB: comfortably covers the 5 MB JSON limit and CSV bulk imports. -->
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
